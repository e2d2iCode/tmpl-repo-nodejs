{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {},
  "overrides": [
    {
      "files": ["*.md", "*.fs-info"],
      "processor": "markdown/markdown",
      "plugins": ["markdown"],
      "rules": {
        "markdown/markdownlint": [
          "error",
          {
            "MD013": false
          }
        ]
      }
    }
  ]
}
